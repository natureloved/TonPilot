# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_WEBHOOK_SECRET=      # Random string you generate e.g. openssl rand -hex 32

# ── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=    # Server-side only, never expose to client

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=            # From console.anthropic.com

# ── TON ───────────────────────────────────────────────────
TON_NETWORK=testnet           # testnet | mainnet
TONCENTER_API_KEY=            # From toncenter.com (optional, higher rate limits)

# ── Price API ─────────────────────────────────────────────
COINGECKO_API_KEY=            # Optional, free tier works fine

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=          # Your Vercel URL e.g. https://tonpilot.vercel.app
CRON_SECRET=                  # Protect your cron endpoint: openssl rand -hex 32
